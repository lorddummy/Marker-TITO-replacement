# Copy this file to .env and fill in values before running.
# At minimum, set at least one of API_KEYS, ADMIN_KEYS, OPERATOR_KEYS, or CAGE_KEYS.

# ── Authentication ────────────────────────────────────────────────────────────

# Full-access (admin) API keys — backward-compatible catch-all.
# Comma-separated. Use ADMIN_KEYS / OPERATOR_KEYS / CAGE_KEYS for finer control.
API_KEYS=changeme-secret-key

# Role-based API keys (optional — use instead of or alongside API_KEYS).
#
#   ADMIN_KEYS     Full access: issue, redeem, void, reports, audit trails.
#   OPERATOR_KEYS  EGM / table system integration: issue, void, extend, batch.
#   CAGE_KEYS      Cage / kiosk readers: validate and redeem only.
#
ADMIN_KEYS=
OPERATOR_KEYS=
CAGE_KEYS=

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000

# CORS origin whitelist. Use '*' to allow any origin (default).
# In production set to your specific frontend origin(s).
CORS_ORIGIN=*

# ── Rate limiting ─────────────────────────────────────────────────────────────

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=200

# ── Database ──────────────────────────────────────────────────────────────────

# SQLite database file path (relative to src/).
# Use an absolute path or mount a volume in production / Docker.
DB_PATH=./data/tito.db

# ── Ticket settings ───────────────────────────────────────────────────────────

# Ticket expiry TTL in seconds (0 = tickets never expire).
TICKET_TTL_SECONDS=86400

# Maximum value of a single ticket in cents.
MAX_TICKET_VALUE_CENTS=10000000

# Comma-separated list of valid property IDs.
# Leave blank to allow any property ID.
ALLOWED_PROPERTY_IDS=

# ── Logging ───────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug
LOG_LEVEL=info
